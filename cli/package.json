{
  "name": "veilpay-mpc-cli",
  "version": "0.1.0",
  "private": true,
  "description": "VeilPay MPC CLI — drive the Arcium confidential payment program from the terminal",
  "bin": {
    "veilpay": "./dist/index.js"
  },
  "scripts": {
    "veilpay": "ts-node src/index.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsup",
    "start": "node ./dist/index.js"
  },
  "dependencies": {
    "@anchor-lang/core": "^1.0.2",
    "@arcium-hq/client": "0.11.2",
    "@solana/spl-token": "^0.4.9",
    "@solana/web3.js": "^1.98.4",
    "@veilpay/sdk": "file:../sdk",
    "commander": "^12.0.0",
    "picocolors": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.0.0",
    "typescript": "^5.7.3"
  }
}
